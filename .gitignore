# Python machinery
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Logs & temporaries
*.log
*.tmp
.pytest_cache/

# Runtime outputs (regenerable; users can run `pex_cold.py` to recreate)
outputs/*

# Tile cache (external; site-specific path via TREEPEX_TILE_CACHE_ROOT)
# Not stored in repo. Document acquisition in docs/.

# External feature CSVs (V4 H3 per-net top-K aggressor; 134 MB for ASAP7).
# Generate locally via archive/pex_v4/scripts/29_extract_new_features.py
# or set TREEPEX_ASAP7_V4_NEW_FEATS / TREEPEX_INTEL22_V4_NEW_FEATS env vars.
inputs/*

# Editor / OS
.DS_Store
.vscode/
.idea/
*.swp

# Numba cache
__numba_cache__/

# Claude Code local state
.claude/
