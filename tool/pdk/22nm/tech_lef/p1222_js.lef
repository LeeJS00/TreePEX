 # FORBIDDEN SPACING to avoid spaces between Vx_23 and Vx_128 on Self Aligned Edges
 # Relevant to Vias where certain offgrid offset spacing for M2 wires will not be allowed if Via spacing falls in Forbidden region
  PROPERTY LEF58_FORBIDDENSPACING "
   FORBIDDENSPACING CUTCLASS Via1_60Sx44 0.061 0.135 LONGEDGEONLY PRL -0.002 TO Via1_60Sx44 -0.002 TO Via1_60Sx56 -0.002 TO Via1_60Sx76 -0.002 TO Via1_60Sx90 -0.002 TO Via1_60Sx108 ;
   FORBIDDENSPACING CUTCLASS Via1_60Sx56 0.061 0.135 LONGEDGEONLY PRL -0.002 TO Via1_60Sx44 -0.002 TO Via1_60Sx56 -0.002 TO Via1_60Sx76 -0.002 TO Via1_60Sx90 -0.002 TO Via1_60Sx108 ;
