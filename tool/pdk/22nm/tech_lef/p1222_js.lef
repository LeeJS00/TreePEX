##################
##ICF rev0, rdua1#
##################

VERSION 5.8 ;

BUSBITCHARS "[]" ;
DIVIDERCHAR "/" ;

UNITS
 DATABASE MICRONS 2000 ;
END UNITS
MANUFACTURINGGRID 0.0005 ;

