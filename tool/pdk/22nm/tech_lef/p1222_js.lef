LAYER v0
  TYPE CUT ;
  SPACING 0.054 ; # V0_24 ;
  PROPERTY LEF58_CUTCLASS "
   CUTCLASS Via0_T_64x44 WIDTH 0.044 LENGTH 0.064 ;
   CUTCLASS Via0_T_68x44S WIDTH 0.044 LENGTH 0.068 ;
 " ;
  PROPERTY LEF58_ENCLOSURE "
   ENCLOSURE CUTCLASS Via0_T_64x44 BELOW END -0.013 SIDE 0.003 ;
   ENCLOSURE CUTCLASS Via0_T_64x44 ABOVE END 0.002 SIDE 0.02 ;
   ENCLOSURE CUTCLASS Via0_T_68x44S BELOW END -0.015 SIDE 0.0 ;
   ENCLOSURE CUTCLASS Via0_T_68x44S ABOVE END 0.0 SIDE 0.0 ;
 " ;


#PROPERTY LEF58_SPACINGTABLE "
#   SPACINGTABLE DEFAULT 0.054  
#   CUTCLASS           Via0_T_64x44 SIDE Via0_T_64x44 END Via0_T_68x44S SIDE Via0_T_68x44S END
#   Via0_T_64x44 SIDE  V0_24 V0_25       - -              V0_24 V0_25        - -              
#   Via0_T_64x44 END   - -               V0_24 -          - -                V0_24 -          
#   Via0_T_68x44S SIDE V0_24 V0_25       - -              V0_24 V0_25        - -              
#   Via0_T_68x44S END  - -               V0_24 -          - -                V0_24 -          # ;
# " ;

PROPERTY LEF58_SPACINGTABLE "
   SPACINGTABLE DEFAULT 0.054  
   CUTCLASS           Via0_T_64x44 SIDE Via0_T_64x44 END Via0_T_68x44S SIDE Via0_T_68x44S END
   Via0_T_64x44 SIDE  - 0.084           - -              - 0.084            - -              
   Via0_T_64x44 END   - -               - -              - -                - -              
   Via0_T_68x44S SIDE - 0.084           - -              - 0.084            - -              
   Via0_T_68x44S END  - -               - -              - -                - -               ;
 " ;

#PROPERTY LEF58_SPACINGTABLE "
#   SPACINGTABLE DEFAULT 0.054 SAMEMETAL 
#   CUTCLASS           Via0_T_64x44 SIDE Via0_T_64x44 END Via0_T_68x44S SIDE Via0_T_68x44S END
#   Via0_T_64x44 SIDE  V0_24 V0_25       - -              V0_24 V0_25        - -              
#   Via0_T_64x44 END   - -               V0_24 -          - -                V0_24 -          
#   Via0_T_68x44S SIDE V0_24 V0_25       - -              V0_24 V0_25        - -              
#   Via0_T_68x44S END  - -               V0_24 -          - -                V0_24 -          # ;
# " ;

PROPERTY LEF58_SPACINGTABLE "
   SPACINGTABLE DEFAULT 0.054 SAMEMETAL 
   CUTCLASS           Via0_T_64x44 SIDE Via0_T_64x44 END Via0_T_68x44S SIDE Via0_T_68x44S END
   Via0_T_64x44 SIDE  - 0.084           - -              - 0.084            - -              
   Via0_T_64x44 END   - -               - -              - -                - -              
   Via0_T_68x44S SIDE - 0.084           - -              - 0.084            - -              
   Via0_T_68x44S END  - -               - -              - -                - -               ;
 " ;
  ANTENNAAREARATIO 9.000 ; # IPN_301 ;

END v0

LAYER m1
  TYPE ROUTING ;
  DIRECTION VERTICAL ;
  PITCH 0.108 ; # calculated ;
  WIDTH 0.068 ; # M1_02 ;
  MINWIDTH 0.044 ; # Changed from .068(M1_02) to OGD width 0.044 ;
  MAXWIDTH 0.1 ;
  SPACING 0.040 ; # M1_31 ;
 ##################################################
 # Width Based Spacing Table
 ##################################################
 PROPERTY LEF58_SPACINGTABLE "
  SPACINGTABLE TWOWIDTHS
   WIDTH  0.000    0.040 0.050
   WIDTH  0.068    0.050 0.050
 ; " ;

  AREA 0.008160 ;
  PROPERTY LEF58_AREA
  "AREA 0.005280 RECTWIDTH 0.044 ;
  AREA 0.008160 RECTWIDTH 0.068 ;
  AREA 0.0120000 RECTWIDTH 0.100 ;
  " ;
  PROPERTY LEF58_WIDTHTABLE "WIDTHTABLE 0.044 0.068 0.1 ;" ;
  PROPERTY LEF58_EOLKEEPOUT "EOLKEEPOUT 0.101 EXTENSION 0.000 0.010 0.046 CLASS M1_E2E CORNERONLY ; " ;
  PROPERTY LEF58_EOLEXTENSIONSPACING "EOLEXTENSIONSPACING 0.056 PARALLELONLY ENDOFLINE 0.101 EXTENSION 0.000 ; " ; # M1_80

  ANTENNAAREARATIO 5000.000 ; # IPN_02 ;
  ANTENNADIFFAREARATIO 3080.000 ; # IPTD_600 ;

END m1

LAYER v1
  TYPE CUT ;
  SPACING 0.046 ; # V1_23 ;
  PROPERTY LEF58_CUTCLASS "
   CUTCLASS Via1_60Sx44 WIDTH 0.044 LENGTH 0.06 ;
   CUTCLASS Via1_60Sx56 WIDTH 0.056 LENGTH 0.06 ;
   CUTCLASS Via1_60Sx76 WIDTH 0.06 LENGTH 0.076 ;
   CUTCLASS Via1_60Sx90 WIDTH 0.06 LENGTH 0.09 ;
   CUTCLASS Via1_60Sx108 WIDTH 0.06 LENGTH 0.108 ;
   CUTCLASS Via1_70x70 WIDTH 0.07 ;
 " ;
  PROPERTY LEF58_ENCLOSURE "
   ENCLOSURE CUTCLASS Via1_60Sx44 BELOW END 0.004 SIDE 0.0 ;
   ENCLOSURE CUTCLASS Via1_60Sx44 ABOVE END 0.022 SIDE 0.0 ;
   ENCLOSURE CUTCLASS Via1_60Sx56 BELOW END 0.004 SIDE 0.01 ;
   ENCLOSURE CUTCLASS Via1_60Sx56 ABOVE END 0.022 SIDE 0.0 ;
   ENCLOSURE CUTCLASS Via1_60Sx76 BELOW END 0.01 SIDE 0.004 ;
   ENCLOSURE CUTCLASS Via1_60Sx76 ABOVE END 0.0 SIDE 0.022 ;
   ENCLOSURE CUTCLASS Via1_60Sx90 BELOW END 0.005 SIDE 0.004 ;
   ENCLOSURE CUTCLASS Via1_60Sx90 ABOVE END 0.0 SIDE 0.022 ;
   ENCLOSURE CUTCLASS Via1_60Sx108 BELOW END -0.004 SIDE 0.004 ;
   ENCLOSURE CUTCLASS Via1_60Sx108 ABOVE END 0.0 SIDE 0.022 ;
   ENCLOSURE CUTCLASS Via1_70x70 BELOW 0.01 0.01 ;
   ENCLOSURE CUTCLASS Via1_70x70 ABOVE 0.003 0.01 ;
 " ;

