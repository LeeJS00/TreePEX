   SPACINGTABLE DEFAULT 0.036 LAYER v0
   CUTCLASS          Via1_60Sx44 SIDE Via1_60Sx44 END Via1_60Sx56 SIDE Via1_60Sx56 END Via1_60Sx76 SIDE Via1_60Sx76 END Via1_60Sx90 SIDE Via1_60Sx90 END Via1_60Sx108 SIDE Via1_60Sx108 END Via1_70x70 SIDE Via1_70x70 END
   Via0_T_64x44 SIDE - -              - -             - -              - -             - -              - -             - -              - -             - -               - -              - -             - -           
   Via0_T_64x44 END  - -              - -             - -              - -             - -              - -             - -              - -             - -               - -              - -             - -           
   Via0_T_68x44S SIDE - -              - -             - -              - -             - -              - -             - -              - -             - -               - -              - -             - -           
   Via0_T_68x44S END - -              - -             - -              - -             - -              - -             - -              - -             - -               - -              - -             - -           
 ; " ;

